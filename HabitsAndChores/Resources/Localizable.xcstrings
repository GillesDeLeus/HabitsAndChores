          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3–20 tekens: letters, cijfers of liggend streepje. Zo vinden vrienden je."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
