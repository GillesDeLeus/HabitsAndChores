    "The day this is up — it shows in Today for whoever it's assigned to (or everyone, if unassigned) on that date." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Tag, an dem es ansteht – es erscheint an diesem Datum in Heute für die zugewiesene Person (oder alle, falls nicht zugewiesen)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El día en que toca: aparece en Hoy para quien esté asignado (o para todos, si no está asignada) en esa fecha."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le jour où elle est due — elle apparaît dans Aujourd’hui pour la personne assignée (ou tout le monde, si non assignée) à cette date."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il giorno in cui scade — appare in Oggi per la persona assegnata (o per tutti, se non assegnata) in quella data."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De dag waarop dit aan de beurt is — het verschijnt in Vandaag voor wie het is toegewezen (of iedereen, indien niet toegewezen) op die datum."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dzień, w którym to przypada — pojawia się w Dziś dla osoby przypisanej (lub dla wszystkich, jeśli nieprzypisane) w tym dniu."
          }
        }
      }
    },
    "The day you plan to do it — it shows up in Today on that date (and stays until you complete it)." : {
      "comment" : "A description of the scheduling feature for a to-do.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Tag, an dem du es erledigen willst – es erscheint an dem Datum in „Heute“ (und bleibt, bis du es abschließt)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El día en que planeas hacerlo: aparece en Hoy en esa fecha (y se queda hasta que lo completes)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le jour où vous prévoyez de le faire — il apparaît dans Aujourd’hui à cette date (et y reste jusqu’à ce que ce soit fait)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il giorno in cui pensi di farlo — appare in Oggi in quella data (e resta finché non lo completi)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De dag waarop je het wilt doen — het verschijnt op die datum in Vandaag (en blijft tot je het voltooit)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dzień, w którym planujesz to zrobić — pojawi się w Dziś tego dnia (i zostanie, aż ukończysz)."
          }
        }
      }
    },
