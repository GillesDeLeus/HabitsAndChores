    "I agree to the Terms & Community Guidelines, and understand there is zero tolerance for objectionable content or abusive behavior." : {
      "comment" : "A checkbox that requires the user to agree to the Terms & Community Guidelines.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich stimme den Nutzungsbedingungen und Community-Richtlinien zu und verstehe, dass es null Toleranz für anstößige Inhalte oder missbräuchliches Verhalten gibt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acepto los Términos y normas de la comunidad y entiendo que hay tolerancia cero con el contenido inapropiado o el comportamiento abusivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "J’accepte les Conditions et règles de la communauté et je comprends qu’il y a une tolérance zéro pour les contenus répréhensibles ou les comportements abusifs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accetto i Termini e le linee guida della community e comprendo che vige tolleranza zero per contenuti offensivi o comportamenti abusivi."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ik ga akkoord met de Voorwaarden en communityrichtlijnen en begrijp dat er nultolerantie geldt voor aanstootgevende inhoud of misbruik."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akceptuję Warunki i wytyczne społeczności oraz rozumiem, że obowiązuje zerowa tolerancja dla nieodpowiednich treści i nadużyć."
          }
        }
      }
    },
