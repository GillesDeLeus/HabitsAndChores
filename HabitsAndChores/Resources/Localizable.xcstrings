    "After each completion this chore passes to the next member automatically. The assignee above is who's up first." : {
      "comment" : "A description of how a task is rotated between household members.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach jedem Erledigen geht diese Aufgabe automatisch an das nächste Mitglied. Die Person oben ist zuerst dran."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tras cada vez que se completa, esta tarea pasa automáticamente al siguiente miembro. La persona de arriba va primero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Après chaque réalisation, cette tâche passe automatiquement au membre suivant. La personne ci-dessus commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dopo ogni completamento questa faccenda passa automaticamente al membro successivo. La persona sopra è la prima."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Na elke voltooiing gaat deze taak automatisch naar het volgende lid. De persoon hierboven is als eerste aan de beurt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po każdym wykonaniu ten obowiązek przechodzi automatycznie na kolejną osobę. Osoba powyżej zaczyna."
          }
        }
      }
    },
