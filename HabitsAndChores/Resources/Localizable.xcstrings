    "3–20 characters: letters, numbers, or underscore. This is how friends find you." : {
      "comment" : "A description of the format of a user's handle.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3–20 Zeichen: Buchstaben, Zahlen oder Unterstrich. So finden dich Freunde."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3–20 caracteres: letras, números o guion bajo. Así te encuentran tus amigos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3 à 20 caractères : lettres, chiffres ou tiret bas. C’est ainsi que vos amis vous trouvent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
