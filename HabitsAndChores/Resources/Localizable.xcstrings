    "“Anytime” isn't available for shared tasks yet — this will be saved as a fixed %@ chore." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Jederzeit“ ist für geteilte Aufgaben noch nicht verfügbar – sie wird als feste %@-Aufgabe gespeichert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«En cualquier momento» aún no está disponible para tareas compartidas: se guardará como una tarea %@ fija."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« À tout moment » n’est pas encore disponible pour les tâches partagées — elle sera enregistrée comme une tâche %@ fixe."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«In qualsiasi momento» non è ancora disponibile per le attività condivise: verrà salvata come faccenda %@ fissa."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‘Op elk moment’ is nog niet beschikbaar voor gedeelde taken — deze wordt opgeslagen als een vaste %@-klus."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„W dowolnym czasie” nie jest jeszcze dostępne dla zadań współdzielonych — zostanie zapisane jako stałe zadanie %@."
          }
        }
      }
    },
