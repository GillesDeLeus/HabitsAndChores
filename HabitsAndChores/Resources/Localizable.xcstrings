    "This permanently deletes your public profile, handle, and friend connections. Your tasks and on-device data are not affected." : {
      "comment" : "A description of the consequences of leaving an account.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht dauerhaft dein öffentliches Profil, deinen Benutzernamen und deine Freundschaften. Deine Aufgaben und lokalen Daten bleiben unberührt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina permanentemente tu perfil público, nombre y amistades. Tus tareas y datos del dispositivo no se ven afectados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime définitivement votre profil public, votre identifiant et vos liens d’amitié. Vos tâches et données locales ne sont pas affectées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo elimina definitivamente profilo pubblico, nome utente e amicizie. Le attività e i dati sul dispositivo non sono interessati."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit verwijdert je openbare profiel, gebruikersnaam en vriendschappen definitief. Je taken en lokale gegevens blijven ongemoeid."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To trwale usuwa profil publiczny, nazwę i znajomości. Twoje zadania i dane na urządzeniu nie są naruszone."
