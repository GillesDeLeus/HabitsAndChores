        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3–20 caracteres: letras, números o guion bajo. Así te encuentran tus amigos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3 à 20 caractères : lettres, chiffres ou tiret bas. C’est ainsi que vos amis vous trouvent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
