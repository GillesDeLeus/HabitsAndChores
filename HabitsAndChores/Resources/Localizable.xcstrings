    "Shared with everyone in the household. Moving a task between Private and a household resets its completion history." : {
      "comment" : "A description of how a task's household assignment affects its completion history.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit dem ganzen Haushalt geteilt. Das Verschieben zwischen Privat und Haushalt setzt den Verlauf zurück."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compartida con todo el hogar. Mover una tarea entre Privado y un hogar reinicia su historial."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partagé avec tout le foyer. Déplacer une tâche entre Privé et un foyer réinitialise son historique."
          }
